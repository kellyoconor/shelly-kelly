  },
  
  "delivery_settings": {
    "whatsapp": {
      "enabled": true,
      "timeout_seconds": 30,
      "target": "Kelly"
    },
    "email_backup": {
      "enabled": false,
      "service": "gmail",
      "user": "kelly@example.com",
      "subject_prefix": "🚨 Critical Alert - Response Needed"
    },
    "response_detection": {
      "auto_mark_window_minutes": 45,
      "confirmation_keywords": ["got it", "thanks", "yes", "no", "ok", "okay"],
      "activity_indicators": ["any message from Kelly within window"]
    }
  },
  
  "monitoring": {
    "heartbeat_frequency": "every heartbeat",
    "health_assessment_frequency": "every 3-4 heartbeats", 
    "gap_processing_frequency": "2-3x daily",
    "daily_report_generation": true,
    "log_retention_days": 30,
    "success_metrics": {
      "critical_delivery_target_minutes": 5,
      "critical_confirmation_target_minutes": 30,
      "urgent_delivery_target_minutes": 10,
      "urgent_confirmation_target_minutes": 60,
      "acceptable_false_positive_rate": 0.20
    }
  },
  
  "file_locations": {
    "alerts_database": "critical-alerts.json",
    "delivery_log": "alert-delivery-log.md",
    "escalated_queue": "escalated-alerts.md",
    "pending_checkins": "pending_checkins.md",
    "health_logs": "memory/welly-health-YYYYMMDD.md",
    "gap_processing_logs": "memory/netty-urgency-YYYYMMDD.md"
  },
  
  "integration": {
    "netty_gap_detection": {
      "enabled": true,
      "automatic_urgency_processing": true,
      "promote_urgent_to_alerts": true
    },
    "welly_health_monitoring": {
      "enabled": true,
      "automatic_health_assessment": true,
      "create_alerts_for_concerns": true
    },
    "proactive_message_system": {
      "enabled": true,
      "handle_normal_priority": true,
      "activity_detection_integration": true
    },
    "heartbeat_system": {
      "enabled": true,
      "priority_order": ["critical_alerts", "health_monitoring", "gap_processing", "standard_checks"]
    }
  },
  
  "tuning_notes": {
    "common_adjustments": [
      "Lower health thresholds if missing important patterns",
      "Raise thresholds if too many false positives",
      "Adjust retry timing based on Kelly's response patterns",
      "Add/remove keywords based on actual usage patterns"
    ],
    "monitoring_tips": [
      "Review daily logs for delivery success rates",

      "resting_hr_elevation_bpm": 15,
      "recovery_score_minimum": 25,
      "consecutive_critical_days": 2
    },
    "urgent_thresholds": {
      "sleep_hours_minimum": 6.0,
      "consecutive_poor_sleep_nights": 2,

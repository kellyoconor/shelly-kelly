      "retry_intervals_minutes": [5, 10, 15],
      "email_backup_timeout_minutes": 30,
      "manual_escalation_timeout_minutes": 120,
      "whatsapp_prefix": "🚨 CRITICAL",
      "description": "Immediate threats to health/safety, time-critical travel issues"
    },
    "URGENT": {
      "retry_intervals_minutes": [10, 20],
      "email_backup_timeout_minutes": 60,
      "manual_escalation_timeout_minutes": 180,
      "whatsapp_prefix": "⚠️ URGENT",
      "description": "Concerning health patterns, important deadlines, urgent follow-ups"
    },
    "NORMAL": {
      "retry_intervals_minutes": [35],
      "email_backup_timeout_minutes": null,
      "manual_escalation_timeout_minutes": null,
      "whatsapp_prefix": null,
      "description": "Standard check-ins, routine follow-ups - uses existing proactive system"
    }
  },
  
  "classification_keywords": {

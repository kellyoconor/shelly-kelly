  "gap_detection": {
    "time_sensitivity_patterns": {
      "critical_time": [
        "tomorrow", "today", "in \\d+ hours?", "flight.*\\d+:\\d+",
        "departure.*\\d+:\\d+", "boarding", "gate", "airport",
        "leaving in", "check[- ]out"
      ],
      "urgent_time": [
        "this week", "deadline", "interview.*\\d+ days? ago",
        "appointment.*yesterday", "results.*waiting",
        "booking.*expires?", "reservation.*pending"
      ]
    },
    "importance_keywords": [
      "health", "medical", "doctor", "hospital", "pain", "sick",
      "flight", "travel", "airport", "hotel", "reservation",
      "interview", "job", "deadline", "application", "urgent",
      "emergency", "family", "mom", "dad"
    ],
    "category_mapping": {
      "travel": ["travel", "flight", "airport", "hotel", "reservation"],
      "health": ["wellness", "health", "medical", "doctor", "pain"],
      "family": ["family", "mom", "dad", "friend", "social"],
      "work": ["work", "interview", "job", "deadline", "application"],
      "general": []
